DATABASE_URL="postgresql://ai_builder:ai_builder_password@localhost:5432/ai_builder"

JWT_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
JWT_EXPIRES_IN="1h"

# 3001 para no chocar con el puerto por defecto de apps/web (3000)
PORT=3001

# Login con Google — credenciales de console.cloud.google.com (proyecto Kroquix)
GOOGLE_CLIENT_ID="pega-aqui-tu-client-id"
GOOGLE_CLIENT_SECRET="pega-aqui-tu-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/v1/auth/google/callback"

# A dónde redirige la API tras un login con Google
FRONTEND_URL="http://localhost:3000"

# Envío de emails (invitaciones) — opcional. Sin esto, las invitaciones
# funcionan igual pero el email se imprime en la consola en vez de enviarse.
# Cuenta gratis en resend.com, la API key empieza por "re_"
RESEND_API_KEY=""
EMAIL_FROM="Kroquix <onboarding@resend.dev>"

# Análisis de negocio con IA (Claude). Cuenta en console.anthropic.com,
# la clave empieza por "sk-ant-"
ANTHROPIC_API_KEY=""

# Agente de WhatsApp (Twilio). Cuenta en twilio.com — el sandbox de WhatsApp
# funciona al instante para probar, sin aprobación de Meta.
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"
